---
const experiences = [
  {
    title: 'Senior Technology Engineer – ET Claims SRE',
    company: 'State Farm',
    location: 'Atlanta, GA',
    period: 'January 2021 – Current',
    highlights: [
      'Established team expectations and architectural standards for multi-region AWS deployments across the Claims organization',
      'Created, piloted, and released a production-grade Terraform module for enterprise consumption; published an open-source module for industry-wide adoption',
      'Coordinated organization-wide migration to SCALR, aligning multiple product teams and reducing operational overhead',
      'Developed a cross-platform (AWS/TP2) event-based monitoring solution using Terraform and Python',
      'Rearchitected Claims Vault usage to increase security posture and adopt change management best practices',
      'Contributed the SSL Lambda Layer to PCAT for enterprise consumption',
      'Set vision and direction as a core member of the Tenant Visions and Architecture (TVA) team',
      'Regularly mentor lead engineers; participated on P7 Software Engineer and P7 Infrastructure Engineer Promotion boards',
      'Selected for a special stability/reliability assignment for TP2 which averted a major platform incident',
    ],
  },
  {
    title: 'Lead Developer – Team Insomnia',
    company: 'State Farm (Volunteer Assignment)',
    location: 'Atlanta, GA',
    period: 'March 2020 – January 2021',
    highlights: [
      'Led Hack Day ATL events in 2020 and 2021, fostering innovation and cross-team collaboration',
      'Implemented GitOps and Terraform Enterprise for production deployment pipelines',
      'Developed CloudWatch queries for monitoring and reporting needs',
      'Coached teams on AWS, Git, and product-team best practices',
    ],
  },
  {
    title: 'Lead Developer – Digital Claims',
    company: 'State Farm',
    location: 'Bloomington, IL / Atlanta, GA',
    period: 'October 2016 – March 2020',
    highlights: [
      'Established and championed the Claims API Ecosystem, communicating methodologies to peers and leadership',
      'Introduced an industry-standard rules engine for authorization and eligibility automation',
      'Architected, developed, and implemented APIs within the Claims API Ecosystem',
      'Created governance regarding API Best Practices across Claims and the Systems Organization',
      'Migrated a high-traffic TP1 Java API to a Node.js AWS API backed by DynamoDB',
      'Established patterns for migrating Business Capability APIs from TP1 to TP2',
    ],
  },
  {
    title: 'Solution Architect – Customer Communications',
    company: 'State Farm',
    location: 'Bloomington, IL / Dallas, TX',
    period: 'April 2012 – October 2016',
    highlights: [
      'Designed and implemented on-demand customer communications solution, increasing efficiency and integration speed',
      'Applied learnings to optimize batch communications system for policy holder printed communications',
      'Implemented a self-service, cookbook-style documentation system to empower consumers',
    ],
  },
];
---

<section class="section experience" id="experience">
  <div class="container">
    <h2 class="section-title">Experience</h2>
    <div class="timeline">
      {experiences.map((exp, i) => (
        <div class="timeline-item">
          <div class="timeline-header">
            <div>
              <h3 class="timeline-role">{exp.title}</h3>
              <p class="timeline-company">{exp.company} · {exp.location}</p>
            </div>
            <span class="timeline-period">{exp.period}</span>
          </div>
          <ul class="timeline-highlights">
            {exp.highlights.map((h) => <li>{h}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .experience {
    padding-top: 100px;
  }

  .timeline {
    position: relative;
    padding-left: 32px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--color-launch-green), transparent);
  }

  .timeline-item {
    position: relative;
    padding-bottom: 48px;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: -36px;
    top: 8px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-launch-green);
    border: 2px solid var(--bg-primary);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .timeline-role {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .timeline-company {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .timeline-period {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .timeline-highlights {
    list-style: none;
  }

  .timeline-highlights li {
    position: relative;
    padding-left: 20px;
    padding-bottom: 12px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .timeline-highlights li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--text-accent);
  }

  @media (max-width: 640px) {
    .timeline-header {
      flex-direction: column;
    }

    .timeline {
      padding-left: 20px;
    }

    .timeline-item::before {
      left: -24px;
    }
  }
</style>
