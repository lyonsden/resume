---
---

<section class="hero" id="top">
  <div class="container">
    <p class="hero-greeting">Hello, I'm</p>
    <h1 class="hero-name">Michael Lyons</h1>
    <h2 class="hero-title">Staff Technology Engineer</h2>
    <p class="hero-description">
      30+ years designing and operating enterprise platforms at scale — from mainframe to cloud-native.
      Specializing in AWS, infrastructure automation, event-driven systems, and SRE.
    </p>
    <div class="hero-actions">
      <a href="#experience" class="btn btn-primary">View Experience</a>
      <a href="https://s.f/lyons-blog" target="_blank" rel="noopener" class="btn btn-secondary">Blog</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 64px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--color-launch-green) 0%, transparent 70%);
    opacity: 0.08;
    pointer-events: none;
  }

  .hero-greeting {
    color: var(--text-accent);
    font-family: var(--font-mono);
    font-size: 1rem;
    margin-bottom: 16px;
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -2px;
    margin-bottom: 16px;
    color: var(--text-primary);
  }

  .hero-title {
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .hero-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 540px;
    margin-bottom: 40px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 12px 28px;
    border-radius: var(--radius-md);
    font-size: 0.95rem;
    font-weight: 600;
    transition: all var(--transition-fast);
    cursor: pointer;
  }

  .btn-primary {
    background: var(--color-launch-green);
    color: #000;
    border: 2px solid var(--color-launch-green);
  }

  .btn-primary:hover {
    background: var(--color-launch-green-hover);
    border-color: var(--color-launch-green-hover);
    color: #000;
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-accent);
    border: 2px solid var(--border-color);
  }

  .btn-secondary:hover {
    border-color: var(--text-accent);
    color: var(--text-accent);
  }

  @media (max-width: 640px) {
    .hero-actions {
      flex-direction: column;
    }

    .btn {
      justify-content: center;
    }
  }
</style>
