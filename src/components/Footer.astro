---
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-info">
        <p class="footer-name">Michael Lyons</p>
        <p class="footer-role">Staff Technology Engineer</p>
      </div>
      <div class="footer-links">
        <a href="mailto:your.email@example.com">Email</a>
      </div>
    </div>
    <p class="footer-copy">Built with Astro. Dark-mode first, R2 themed.</p>
  </div>
</footer>

<style>
  .footer {
    padding: 48px 0;
    border-top: 1px solid var(--border-color);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .footer-role {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .footer-links {
    display: flex;
    gap: 24px;
  }

  .footer-links a {
    color: var(--text-secondary);
    font-size: 0.9rem;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--text-accent);
  }

  .footer-copy {
    color: var(--text-muted);
    font-size: 0.85rem;
  }
</style>
