---
const projects = [
  {
    title: 'AI-Powered Code Review & MR Orchestration',
    description: 'Built an event-driven platform (SQS/DynamoDB/ECS-Fargate/Bedrock) that provides automatic merge request summarization, on-demand code review, and orchestrates codebase-wide changes across 2,000+ repos. Engineers request reviews or bulk updates via MR; the system generates complete merge requests for team review.',
    tags: ['Bedrock', 'Claude 4.6', 'Event-Driven', 'ECS/Fargate', 'SQS', 'DynamoDB'],
  },
  {
    title: 'Enterprise Copilot Customizations',
    description: 'Forked the public awesome-copilot repository for internal Claims use, rapidly adopted enterprise-wide. Published internal Copilot customizations for API Standards, Well-Architected patterns, and a manager prompt that auto-installs relevant customizations based on the engineer\'s current project. Over 20 contributors have shared customizations through this project.',
    tags: ['GitHub Copilot', 'AI-Assisted Development', 'Internal Platform'],
  },
  {
    title: 'Open-Source Terraform Module',
    description: 'Published a production-grade Terraform module to the StateFarmIns GitHub organization for industry-wide adoption, enabling standardized infrastructure provisioning.',
    url: 'https://github.com/StateFarmIns/terraform-aws-ip-address-release',
    tags: ['Terraform', 'IaC', 'Open Source'],
  },
  {
    title: 'Cross-Platform Event Monitoring',
    description: 'Developed an event-based monitoring solution spanning AWS and internal cloud platforms using Terraform and Python, providing real-time observability across heterogeneous environments.',
    tags: ['Python', 'AWS', 'Event-Driven', 'Observability'],
  },
  {
    title: 'Claims API Ecosystem',
    description: 'Established and championed the Claims API Ecosystem, introducing governance, best practices, and an industry-standard rules engine for authorization and eligibility.',
    tags: ['API Design', 'Node.js', 'Governance', 'Rules Engine'],
  },
  {
    title: 'SSL Lambda Layer',
    description: 'Contributed the SSL Lambda Layer to the enterprise cloud adoption team for organization-wide consumption, streamlining SSL certificate management across AWS Lambda functions.',
    tags: ['AWS Lambda', 'Security', 'Enterprise'],
  },
];
---

<section class="section projects" id="projects">
  <div class="container">
    <h2 class="section-title">Notable Projects</h2>
    <div class="projects-grid">
      {projects.map((p) => (
        <div class="project-card">
          <h3 class="project-title">
            {p.url ? <a href={p.url} target="_blank" rel="noopener">{p.title} ↗</a> : p.title}
          </h3>
          <p class="project-description">{p.description}</p>
          <div class="project-tags">
            {p.tags.map((t) => <span class="badge">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }

  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: border-color var(--transition-fast), transform var(--transition-fast);
  }

  .project-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
  }

  .project-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .project-title a {
    color: var(--text-primary);
  }

  .project-title a:hover {
    color: var(--text-accent);
  }

  .project-description {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    flex-grow: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
</style>
