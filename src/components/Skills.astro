---
const skillCategories = [
  {
    name: 'Cloud & Infrastructure',
    skills: ['AWS (Lambda, SQS, RDS, DynamoDB)', 'Multi-region Architecture', 'Event-Driven Systems', 'Terraform / TFE / Scalr', 'Docker', 'HashiCorp Vault'],
  },
  {
    name: 'Languages',
    skills: ['Python', 'Node.js', 'Java', 'Go', 'PL/I'],
  },
  {
    name: 'Platforms & Tools',
    skills: ['GitLab CI', 'Jenkins', 'GitOps', 'CloudWatch', 'X-Ray', 'Dynatrace', 'GitHub'],
  },
  {
    name: 'Practices',
    skills: ['SRE & Resiliency', 'DevSecOps', 'Infrastructure as Code', 'API Governance', 'Technical Leadership', 'AI-Assisted Development'],
  },
];

const certifications = ['AWS Cloud Practitioner', 'Chartered Financial Consultant (ChFC)'];
---

<section class="section skills" id="skills">
  <div class="container">
    <h2 class="section-title">Skills & Certifications</h2>
    <div class="skills-grid">
      {skillCategories.map((cat) => (
        <div class="skill-card">
          <h3 class="skill-category">{cat.name}</h3>
          <div class="skill-tags">
            {cat.skills.map((s) => <span class="badge">{s}</span>)}
          </div>
        </div>
      ))}
    </div>
    <div class="certifications">
      <h3 class="cert-title">Certifications</h3>
      <div class="cert-badges">
        {certifications.map((c) => <span class="badge badge-cert">{c}</span>)}
      </div>
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-bottom: 48px;
  }

  .skill-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 24px;
    transition: border-color var(--transition-fast), transform var(--transition-fast);
  }

  .skill-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
  }

  .skill-category {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .badge {
    display: inline-block;
    padding: 6px 12px;
    background: var(--bg-tertiary);
    color: var(--text-accent);
    border: 1px solid var(--border-color);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 500;
    font-family: var(--font-mono);
    transition: border-color var(--transition-fast);
  }

  .badge:hover {
    border-color: var(--text-accent);
  }

  .certifications {
    padding: 24px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
  }

  .cert-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
  }

  .cert-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .badge-cert {
    background: transparent;
    border-color: var(--color-launch-green);
  }
</style>
